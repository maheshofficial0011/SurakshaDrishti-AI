"""
SurakshaNet AI — Assistant Placeholder Patch

Purpose:
- Add AI Assistant sidebar section safely.
- Add placeholder page only.
- No chatbot logic yet.
- No backend changes.
- No architecture changes.
- No new npm packages.

Safety:
- Only modifies frontend/dashboard/src/App.jsx.
- Creates backup before editing.
"""

from pathlib import Path


APP_PATH = Path("frontend/dashboard/src/App.jsx")
BACKUP_PATH = Path("frontend/dashboard/src/App.jsx.backup_before_assistant_placeholder")


def replace_once(text: str, old: str, new: str, label: str) -> str:
    if old not in text:
        raise RuntimeError(f"Could not find expected block: {label}")
    return text.replace(old, new, 1)


def main():
    if not APP_PATH.exists():
        raise FileNotFoundError(APP_PATH)

    source = APP_PATH.read_text(encoding="utf-8")

    if not BACKUP_PATH.exists():
        BACKUP_PATH.write_text(source, encoding="utf-8")

    text = source

    # ------------------------------------------------------------
    # 1. Add AI Assistant sidebar item before Settings
    # ------------------------------------------------------------

    old_sidebar_block = '''            <SidebarItem
                icon="📈"
                label="Analytics"
                active={activeSection === "analytics"}
                onClick={() => setActiveSection("analytics")}
            />

            <SidebarItem
                icon="⚙️"
                label="Settings"
                active={activeSection === "settings"}
                onClick={() => setActiveSection("settings")}
            />'''

    new_sidebar_block = '''            <SidebarItem
                icon="📈"
                label="Analytics"
                active={activeSection === "analytics"}
                onClick={() => setActiveSection("analytics")}
            />

            <SidebarItem
                icon="🤖"
                label="AI Assistant"
                active={activeSection === "assistant"}
                onClick={() => setActiveSection("assistant")}
            />

            <SidebarItem
                icon="⚙️"
                label="Settings"
                active={activeSection === "settings"}
                onClick={() => setActiveSection("settings")}
            />'''

    text = replace_once(text, old_sidebar_block, new_sidebar_block, "sidebar assistant item")

    # ------------------------------------------------------------
    # 2. Add Assistant placeholder section config
    # ------------------------------------------------------------

    old_section_config = '''        analytics: {
            icon: "📈",
            title: "Analytics Section",
            description:
                "This section is ready. Next step can move analytics cards and reports here safely.",
        },'''

    new_section_config = '''        analytics: {
            icon: "📈",
            title: "Analytics Section",
            description:
                "This section is ready. Next step can move analytics cards and reports here safely.",
        },
        assistant: {
            icon: "🤖",
            title: "SurakshaNet Command Assistant",
            description:
                "This section is ready. Next step will add a local dashboard assistant connected to alerts, heatmap, SOS, and authority data.",
        },'''

    text = replace_once(text, old_section_config, new_section_config, "assistant placeholder config")

    APP_PATH.write_text(text, encoding="utf-8")

    print("assistant placeholder patch ok")
    print(f"backup: {BACKUP_PATH}")
    print(f"updated: {APP_PATH}")


if __name__ == "__main__":
    main()
