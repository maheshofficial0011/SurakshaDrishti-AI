                            ))}
                        </div>
                    </div>

                    <div
                        style={{
                            marginTop: "16px",
                            background: "#1e3a8a",
                            border: "1px solid #60a5fa",
                            borderRadius: "14px",
                            padding: "14px",
                            color: "#dbeafe",
                            fontWeight: "bold",
