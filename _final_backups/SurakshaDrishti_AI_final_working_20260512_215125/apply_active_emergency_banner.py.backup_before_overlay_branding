"""
SurakshaNet AI — Active Emergency Banner Patch

Purpose:
- Add a top-level active emergency banner.
- Show unresolved SOS / CRITICAL / HIGH incidents clearly.
- Let operator jump to Alerts or Authority sections.
- Do not change backend.
- Do not change architecture.

Safety:
- Only modifies frontend/dashboard/src/App.jsx.
- Creates backup before editing.
"""

from pathlib import Path


APP_PATH = Path("frontend/dashboard/src/App.jsx")
BACKUP_PATH = Path("frontend/dashboard/src/App.jsx.backup_before_active_emergency_banner")


def replace_once(text: str, old: str, new: str, label: str) -> str:
    if old not in text:
        raise RuntimeError(f"Could not find expected block: {label}")
    return text.replace(old, new, 1)


def insert_before(text: str, marker: str, insert: str, label: str) -> str:
    if marker not in text:
        raise RuntimeError(f"Could not find marker: {label}")
    return text.replace(marker, insert + marker, 1)


def main():
    source = APP_PATH.read_text(encoding="utf-8")

    if not BACKUP_PATH.exists():
        BACKUP_PATH.write_text(source, encoding="utf-8")

    text = source

    # ------------------------------------------------------------
    # 1. Insert ActiveEmergencyBanner after ErrorBanner
    # ------------------------------------------------------------

    old_block = '''                {lastError && <ErrorBanner message={lastError} />}'''

    new_block = '''                {lastError && <ErrorBanner message={lastError} />}

                {latestCritical && (
                    <ActiveEmergencyBanner
                        event={latestCritical}
                        dispatches={dispatches}
                        getEventIcon={getEventIcon}
                        setActiveSection={setActiveSection}
                    />
                )}'''

    text = replace_once(text, old_block, new_block, "insert ActiveEmergencyBanner")

    # ------------------------------------------------------------
    # 2. Remove duplicate old CriticalAlertBanner from dashboard body
    # ------------------------------------------------------------
    # It may still exist below controls. Remove it so banner does not duplicate.

    old_critical_block = '''                        {latestCritical && (
                            <CriticalAlertBanner
                                event={latestCritical}
                                getEventIcon={getEventIcon}
                            />
                        )}

'''

    if old_critical_block in text:
        text = text.replace(old_critical_block, "", 1)

    # ------------------------------------------------------------
    # 3. Add ActiveEmergencyBanner component before CriticalAlertBanner
    # ------------------------------------------------------------

    component_code = r'''function ActiveEmergencyBanner({
    event,
    dispatches,
    getEventIcon,
    setActiveSection,
}) {
    if (!event) {
        return null
    }

    const relatedDispatches = (dispatches || []).filter(
        (dispatch) => Number(dispatch.event_id) === Number(event.db_id)
    )

    const unresolvedDispatches = relatedDispatches.filter(
        (dispatch) => dispatch.status !== "RESOLVED"
    )

    const statusText =
        unresolvedDispatches.length > 0
            ? unresolvedDispatches
                .map((dispatch) =>
                    dispatch.status === "DISPATCHED" ? "RUNNING" : dispatch.status
                )
                .join(", ")
            : "ACTIVE"

    const helpNeeded = Array.isArray(event.help_needed)
        ? event.help_needed.join(", ")
        : event.help_needed || "Authority response required"

    return (
        <div
            style={{
                background: "linear-gradient(90deg, #7f1d1d, #111827)",
                border: "1px solid #ef4444",
                borderLeft: "8px solid #dc2626",
                borderRadius: "18px",
                padding: "16px 18px",
                marginBottom: "18px",
                animation: "pulseAlert 1.5s infinite",
            }}
        >
            <div
                style={{
                    display: "flex",
                    justifyContent: "space-between",
                    gap: "14px",
                    alignItems: "flex-start",
                }}
            >
                <div>
                    <div
                        style={{
                            color: "#fecaca",
                            fontSize: "12px",
                            fontWeight: "bold",
                            marginBottom: "7px",
                            letterSpacing: "0.5px",
                        }}
                    >
                        ACTIVE EMERGENCY — PINNED UNTIL RESOLVED
                    </div>

                    <div style={{ fontSize: "22px", fontWeight: "bold" }}>
                        {getEventIcon(event.type)} {event.type}
                    </div>

                    <div style={{ color: "#e5e7eb", marginTop: "6px", lineHeight: 1.5 }}>
                        {event.message || "High-priority surveillance event detected"}
                    </div>

                    <div
                        style={{
                            display: "grid",
                            gridTemplateColumns: "repeat(3, minmax(0, 1fr))",
                            gap: "10px",
                            marginTop: "12px",
                        }}
                    >
                        <EmergencyInfoItem
                            label="Incident"
                            value={event.incident_type || event.type || "Emergency"}
                        />

                        <EmergencyInfoItem
                            label="Help Needed"
                            value={helpNeeded}
                        />

                        <EmergencyInfoItem
                            label="Authority Status"
                            value={statusText}
                        />

                        <EmergencyInfoItem
                            label="Location"
                            value={
                                event.incident_location ||
                                event.location_label ||
                                event.camera_location ||
                                "Demo Laptop Location"
                            }
                        />

                        <EmergencyInfoItem
                            label="Source"
                            value={event.source || "camera_ai"}
                        />

                        <EmergencyInfoItem
                            label="DB ID"
                            value={event.db_id || "Pending"}
                        />
                    </div>
                </div>

                <div
                    style={{
                        display: "flex",
                        flexDirection: "column",
                        gap: "10px",
                        minWidth: "150px",
                    }}
                >
                    <button
                        onClick={() => setActiveSection("alerts")}
                        style={{
                            background: "#dc2626",
                            color: "white",
                            border: "1px solid #fecaca",
                            borderRadius: "12px",
                            padding: "10px 12px",
                            fontWeight: "bold",
                        }}
                    >
                        View Alert
                    </button>

                    <button
                        onClick={() => setActiveSection("authority")}
                        style={{
                            background: "#2563eb",
                            color: "white",
                            border: "1px solid #93c5fd",
                            borderRadius: "12px",
                            padding: "10px 12px",
                            fontWeight: "bold",
                        }}
                    >
                        Authority
                    </button>
                </div>
            </div>
        </div>
    )
}

function EmergencyInfoItem({ label, value }) {
    return (
        <div
            style={{
                background: "rgba(15, 23, 42, 0.8)",
                border: "1px solid rgba(248, 113, 113, 0.35)",
                borderRadius: "12px",
                padding: "10px",
                minWidth: 0,
            }}
        >
            <div
                style={{
                    color: "#fca5a5",
                    fontSize: "11px",
                    fontWeight: "bold",
                    marginBottom: "4px",
                }}
            >
                {label}
            </div>

            <div
                style={{
                    color: "#f8fafc",
                    fontSize: "13px",
                    fontWeight: "bold",
                    overflowWrap: "break-word",
                }}
            >
                {value}
            </div>
        </div>
    )
}

'''

    text = insert_before(
        text,
        "function CriticalAlertBanner({ event, getEventIcon }) {",
        component_code,
        "before CriticalAlertBanner",
    )

    APP_PATH.write_text(text, encoding="utf-8")

    print("active emergency banner patch ok")
    print(f"backup: {BACKUP_PATH}")
    print(f"updated: {APP_PATH}")


if __name__ == "__main__":
    main()