"""
SurakshaNet AI — Authority Incident Dispatcher Service

Purpose:
- Create authority response incident records for dashboard workflow.
- Keep this separate from the existing alert_system.dispatcher module.
- Avoid changing Event Engine, detection, tracking, or camera pipeline.

Workflow:
- Alert/SOS occurs
- Backend creates authority incident with status PENDING
- Dashboard operator can later:
  PENDING -> ASSIGNED -> DISPATCHED/RUNNING -> RESOLVED

Important:
- No real police/ambulance/fire APIs are called.
- No external network calls.
- No background jobs.
- This is a local demo-safe incident workflow.
"""

from datetime import datetime

from backend.app.demo_config import get_demo_location


def _build_dispatch_id(event_id=None, unit_index=None):
    """
    Create a readable authority incident/dispatch id.

    Examples:
    DSP-0001
    DSP-0001-2
    """

    if event_id is None:
        base_id = f"DSP-{int(datetime.now().timestamp())}"
    else:
        try:
            base_id = f"DSP-{int(event_id):04d}"
        except Exception:
            base_id = f"DSP-{int(datetime.now().timestamp())}"

    if unit_index is not None:
        return f"{base_id}-{unit_index}"

    return base_id


def _unit_for_help_type(help_type: str):
    """
    Map requested help type to a demo response unit.

    Supported help types:
    - POLICE
    - AMBULANCE
    - FIRE
    - RESCUE
    - SECURITY
    """

    help_type = (help_type or "").upper()

    unit_map = {
        "POLICE": {
            "unit_type": "POLICE",
            "unit_name": "UNIT-01 ALPHA",
            "eta_minutes": 3,
        },
        "AMBULANCE": {
            "unit_type": "AMBULANCE",
            "unit_name": "AMBULANCE-01",
            "eta_minutes": 5,
        },
        "FIRE": {
            "unit_type": "FIRE",
            "unit_name": "FIRE-01",
            "eta_minutes": 6,
        },
        "RESCUE": {
            "unit_type": "RESCUE",
            "unit_name": "RESCUE-01",
            "eta_minutes": 7,
        },
        "SECURITY": {
            "unit_type": "SECURITY",
            "unit_name": "SECURITY-PATROL-01",
            "eta_minutes": 4,
        },
    }

    return unit_map.get(help_type)


def _select_units_for_event(event: dict):
    """
    Pick suggested authority units based on event type and SOS help_needed.

    For SOS:
    - Prefer user-selected help_needed list.
    - If missing, default to POLICE + AMBULANCE.

    For AI alerts:
    - HIGH/CRITICAL intrusion/crowd/weapon alerts create POLICE incident.
    """

    event_type = (event.get("type") or "").upper()
    severity = (event.get("severity") or "").upper()

    if event_type == "SOS_ALERT":
        help_needed = event.get("help_needed") or ["POLICE", "AMBULANCE"]

        units = []

        for help_type in help_needed:
            unit = _unit_for_help_type(help_type)

            if unit:
                units.append(unit)

        if units:
            return units

        return [
            {
                "unit_type": "POLICE",
                "unit_name": "UNIT-01 ALPHA",
                "eta_minutes": 3,
            },
            {
                "unit_type": "AMBULANCE",
                "unit_name": "AMBULANCE-01",
                "eta_minutes": 5,
            },
        ]

    if event_type == "WEAPON_DETECTED":
        return [
            {
                "unit_type": "POLICE",
                "unit_name": "UNIT-01 ALPHA",
                "eta_minutes": 3,
            }
        ]

    if event_type in ["INTRUSION", "CROWD_ALERT"] or severity in ["CRITICAL", "HIGH"]:
        return [
            {
                "unit_type": "POLICE",
                "unit_name": "UNIT-01 ALPHA",
                "eta_minutes": 4,
            }
        ]

    return []


def create_dispatches_for_event(event: dict, event_id=None):
    """
    Create authority incident records for an event.

    New behavior:
    - Records start as PENDING.
    - Dashboard operator controls:
      Assign -> Dispatch/Running -> Resolve.

    Args:
        event:
            Event dictionary saved/broadcast by backend.
        event_id:
            SQLite event row id.

    Returns:
        list[dict]: dispatch/incident records ready to save and broadcast.
    """

    if not event:
        return []

    units = _select_units_for_event(event)

    if not units:
        return []

    location = event.get("location") or get_demo_location()

    location_label = (
        event.get("incident_location")
        or event.get("location_label")
        or event.get("camera_location")
        or location.get("label")
        or "Demo Laptop Location"
    )

    created_at = datetime.now().isoformat()
    dispatches = []

    for index, unit in enumerate(units, start=1):
        dispatch = {
            "dispatch_id": _build_dispatch_id(
                event_id, index if len(units) > 1 else None
            ),
            "event_id": event_id,
            "event_type": event.get("type", "UNKNOWN"),
            "unit_type": unit["unit_type"],
            "unit_name": unit["unit_name"],
            # Important workflow change:
            # New incidents wait for operator action.
            "status": "PENDING",
            "eta_minutes": unit["eta_minutes"],
            "location_label": location_label,
            "created_at": created_at,
            # Extra fields for realistic authority workflow UI.
            "incident_type": event.get("incident_type"),
            "help_needed": event.get("help_needed", []),
            "details": event.get("details") or event.get("message"),
            "severity": event.get("severity", "INFO"),
        }

        dispatches.append(dispatch)

    return dispatches
