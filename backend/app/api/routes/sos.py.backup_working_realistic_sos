"""
SurakshaNet AI — SOS Demo API Route

Purpose:
- Simulate a realistic mobile SOS emergency request.
- Collect incident details from dashboard SOS form.
- Create a critical SOS event.
- Save it to SQLite.
- Broadcast it to dashboard through the existing WebSocket system.
- Create PENDING authority response incidents based on help_needed.

Important:
- This does NOT create a real mobile app.
- This does NOT call police/ambulance/fire APIs.
- This does NOT use GPS.
- It uses the configured demo laptop location unless a custom incident_location
  is provided by the dashboard form.
"""

from datetime import datetime

from fastapi import APIRouter

from backend.app.database import save_event, save_dispatch
from backend.app.demo_config import enrich_event_with_demo_location
from backend.app.services.demo_dispatcher import create_dispatches_for_event
from backend.app.websocket_manager import broadcast_event

router = APIRouter()


def _normalize_help_needed(value):
    """
    Normalize help_needed field into a clean uppercase list.

    Accepted input examples:
    - ["POLICE", "AMBULANCE"]
    - "POLICE"
    - None

    Returns:
        list[str]
    """

    if value is None:
        return ["POLICE", "AMBULANCE"]

    if isinstance(value, str):
        value = [value]

    if not isinstance(value, list):
        return ["POLICE", "AMBULANCE"]

    cleaned = []

    allowed = {"POLICE", "AMBULANCE", "FIRE", "RESCUE", "SECURITY"}

    for item in value:
        item = str(item).strip().upper()

        if item in allowed and item not in cleaned:
            cleaned.append(item)

    if not cleaned:
        return ["POLICE", "AMBULANCE"]

    return cleaned


@router.post("/sos")
async def trigger_sos(payload: dict | None = None):
    """
    Trigger a realistic demo SOS alert.

    Request body example:
    {
        "user_name": "Demo User",
        "phone": "demo",
        "incident_location": "Demo Laptop Location",
        "incident_type": "Medical Emergency",
        "help_needed": ["POLICE", "AMBULANCE"],
        "details": "Person injured near main gate"
    }

    Returns:
        Created SOS event and PENDING authority response records.
    """

    payload = payload or {}

    user_name = payload.get("user_name", "Demo User")
    phone = payload.get("phone", "demo")

    incident_location = payload.get(
        "incident_location",
        payload.get("location_label", "Demo Laptop Location"),
    )

    incident_type = payload.get("incident_type", "General Emergency")

    help_needed = _normalize_help_needed(payload.get("help_needed"))

    details = payload.get(
        "details",
        payload.get("message", "Emergency SOS triggered from mobile app demo"),
    )

    help_text = ", ".join(help_needed)

    sos_event = {
        "type": "SOS_ALERT",
        "severity": "CRITICAL",
        "message": (
            f"SOS alert from {user_name}. "
            f"Incident: {incident_type}. "
            f"Help needed: {help_text}. "
            f"Details: {details}"
        ),
        "source": "mobile_app",
        "user_name": user_name,
        "phone": phone,
        "incident_location": incident_location,
        "incident_type": incident_type,
        "help_needed": help_needed,
        "details": details,
        "timestamp": datetime.now().isoformat(),
        "class": "sos",
        "class_name": "sos",
        "object_label": "mobile_sos",
        "object_confidence": 1.0,
        "confidence": 1.0,
        "camera_id": "MOBILE-SOS",
        "camera_name": "Mobile SOS Demo",
        "camera_location": incident_location,
        "location_label": incident_location,
    }

    sos_event = enrich_event_with_demo_location(sos_event)

    event_id = save_event(sos_event)
    sos_event["db_id"] = event_id

    await broadcast_event(sos_event)

    dispatches = create_dispatches_for_event(sos_event, event_id=event_id)

    for dispatch in dispatches:
        dispatch_db_id = save_dispatch(dispatch)
        dispatch["id"] = dispatch_db_id

        await broadcast_event(
            {
                "type": "DISPATCH_UPDATE",
                "severity": "INFO",
                "message": (
                    f"{dispatch['unit_name']} added to Authority Response Center "
                    f"for {dispatch['location_label']} "
                    f"with status {dispatch['status']}"
                ),
                "dispatch": dispatch,
                "source": "authority_response_center",
            }
        )

    return {
        "success": True,
        "event": sos_event,
        "dispatches": dispatches,
    }